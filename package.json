{
  "name": "scratch-map",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "modules/*"
  ],
  "scripts": {
    "start:api": "cd modules/api && bun run dev",
    "start:grid-wars": "cd modules/grid-wars && bunx expo start",
    "dev": "bunx concurrently --names \"api,grid-wars\" --prefix-colors \"yellow,blue\" \"bun run start:api\" \"bun run start:grid-wars\""
  }
}
